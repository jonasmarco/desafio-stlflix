{
  "name": "stlflix-pedido-bridge",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "perf:lighthouse": "mkdir -p reports && lighthouse ${TARGET_URL:-http://localhost:3000} --chrome-flags='--headless=new --no-sandbox --ignore-certificate-errors --allow-insecure-localhost' --only-categories=performance,accessibility,best-practices --output=json --output-path=reports/lighthouse.json",
    "quality": "pnpm lint && pnpm test && pnpm build && pnpm test:e2e && pnpm build-storybook"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "sonner": "2.0.7",
    "tailwindcss": "^4.3.0",
    "web-vitals": "5.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/nextjs": "10.4.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "jsdom": "29.1.1",
    "lighthouse": "13.3.0",
    "prettier": "3.8.3",
    "storybook": "10.4.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
